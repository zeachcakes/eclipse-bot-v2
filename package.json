{
  "name": "eclipse-bot-v2",
  "version": "2.0.0",
  "description": "Discord bot for Reddit Eclipse - a Clash of Clans community",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "dev-env": "set NODE_ENV=development&& node --watch src/index.js",
    "prod-env": "set NODE_ENV=production&& node src/index.js",
    "deploy": "node src/deploy-commands.js",
    "db:migrate": "dotenv -e .env.development -- npx prisma migrate dev",
    "db:migrate:prod": "dotenv -e .env.production -- npx prisma migrate deploy",
    "db:push": "dotenv -e .env.development -- npx prisma db push",
    "db:push:prod": "dotenv -e .env.production -- npx prisma db push",
    "db:studio": "dotenv -e .env.development -- npx prisma studio",
    "db:studio:prod": "dotenv -e .env.production -- npx prisma studio",
    "db:generate": "npx prisma generate",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "prepare": "husky && npx prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.20.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prisma": "^7.4.2"
  },
  "lint-staged": {
    "*.js": "eslint --fix"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "ISC"
}
