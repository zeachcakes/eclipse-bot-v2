# Discord Bot
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here

# Set this for guild-scoped command deployment (instant updates during development)
# Leave empty to deploy globally (takes up to 1 hour)
GUILD_ID=your_dev_guild_id_here

# Clash of Clans API (https://developer.clashofclans.com)
COC_API_TOKEN=your_coc_api_token_here
