# ── Discord Bot ────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here

# Set for guild-scoped command deployment (instant updates during dev)
# Leave empty to deploy globally (up to 1 hour)
GUILD_ID=your_dev_guild_id_here

# ── Clash of Clans API ─────────────────────────────────────────
# https://developer.clashofclans.com
COC_API_TOKEN=your_coc_api_token_here

# ── Server ─────────────────────────────────────────────────────
ECLIPSE=eclipse_server_id

# ── Category Channels ──────────────────────────────────────────
CLAN_CATEGORY=clan_category_channel_id
LEADERSHIP_CATEGORY=leadership_category_channel_id
WARROOM_CATEGORY=war_room_category_channel_id

# ── Channels ───────────────────────────────────────────────────
DEVELOPMENT=development_channel_id
DONATION=donations_channel_id
LEADERNOTES=leader_notes_channel_id
LEADERSHIP=leadership_channel_id
WARDISCUSSION=war_discussion_channel_id
WELCOME=welcome_channel_id
WMBOT=wmbot_channel_id

# ── Roles ──────────────────────────────────────────────────────
ADMIN_ROLE=admin_role_id
BOTS_ROLE=bots_role_id
CO_LEADER_ROLE=co_leader_role_id
ELDER_ROLE=elder_role_id
ECLIPSE_ROLE=eclipse_role_id
FRIENDS_ROLE=friends_role_id
INWAR_ROLE=in_war_role_id
LEADERSHIP_ROLE=leadership_role_id
MUTED_ROLE=muted_role_id
POWERDONATOR_ROLE=power_donator_role_id
VISITOR_ROLE=visitor_role_id
WARCOUNSELOR_ROLE=war_counselor_role_id
WARGUEST_ROLE=war_guest_role_id

# ── Users ──────────────────────────────────────────────────────
JAY=jay_user_id
LUIGI=luigi_user_id
PAUL=paul_user_id
PERIL=peril_user_id
PROTOTYPE=prototype_user_id
RANCH=ranch_user_id
