generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Mute {
  id          Int      @id @default(autoincrement())
  userId      String
  guildId     String
  moderatorId String
  reason      String
  expiresAt   DateTime
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([userId, guildId])
  @@index([active, expiresAt])
}

model KickLog {
  id          Int      @id @default(autoincrement())
  userId      String
  guildId     String
  moderatorId String
  reason      String
  createdAt   DateTime @default(now())

  @@index([userId, guildId])
}

model KickCooldown {
  userId     String
  guildId    String
  lastKickAt DateTime

  @@id([userId, guildId])
}

model WarnLog {
  id          Int      @id @default(autoincrement())
  userId      String
  guildId     String
  moderatorId String
  reason      String
  createdAt   DateTime @default(now())

  @@index([userId, guildId])
}

model UserRank {
  userId       String
  guildId      String
  messageCount Int      @default(0)
  xp           Int      @default(0)
  rankLevel    Int      @default(1)
  updatedAt    DateTime @updatedAt

  @@id([userId, guildId])
  @@index([guildId, xp(sort: Desc)])
}

model GuildRankConfig {
  guildId   String
  rankLevel Int
  name      String

  @@id([guildId, rankLevel])
}

model UserFlair {
  userId  String
  guildId String
  flair   String

  @@id([userId, guildId])
}

model GuildFlairPool {
  guildId String
  emoji   String
  label   String?

  @@id([guildId, emoji])
}

model GuildSetting {
  guildId    String  @id
  banGifMode Boolean @default(true)
}

model BanLog {
  id          Int      @id @default(autoincrement())
  userId      String
  guildId     String
  moderatorId String
  reason      String
  createdAt   DateTime @default(now())

  @@index([userId, guildId])
}

model PlayerLink {
  userId    String
  guildId   String
  playerTag String
  createdAt DateTime @default(now())

  @@id([userId, guildId])
  @@index([playerTag])
}

model DonationSeasonSnapshot {
  playerTag              String
  seasonKey              String
  baselineAchievement    Int
  currentSeasonDonations Int      @default(0)
  finalDonations         Int?
  createdAt              DateTime @default(now())

  @@id([playerTag, seasonKey])
  @@index([seasonKey])
  @@index([playerTag])
}
