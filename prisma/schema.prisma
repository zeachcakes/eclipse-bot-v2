generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model GuildMember {
  userId       String
  guildId      String
  messageCount Int       @default(0)
  xp           Int       @default(0)
  rankLevel    Int       @default(1)
  flair        String?
  kickLastAt   DateTime? // moderator kick cooldown tracker
  updatedAt    DateTime  @updatedAt

  mutes       Mute[]    @relation("MuteTarget")
  kicks       KickLog[] @relation("KickTarget")
  warns       WarnLog[] @relation("WarnTarget")
  bans        BanLog[]  @relation("BanTarget")

  mutesIssued Mute[]    @relation("MuteModerator")
  kicksIssued KickLog[] @relation("KickModerator")
  warnsIssued WarnLog[] @relation("WarnModerator")
  bansIssued  BanLog[]  @relation("BanModerator")

  clanLinks ClanMember[]

  @@id([userId, guildId])
  @@index([guildId, xp(sort: Desc)])
}

model Mute {
  id          Int      @id @default(autoincrement())
  userId      String
  guildId     String
  moderatorId String
  reason      String
  expiresAt   DateTime
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  target    GuildMember @relation("MuteTarget",    fields: [userId, guildId],      references: [userId, guildId], onDelete: Restrict)
  moderator GuildMember @relation("MuteModerator", fields: [moderatorId, guildId], references: [userId, guildId], onDelete: Restrict)

  @@index([userId, guildId])
  @@index([active, expiresAt])
}

model KickLog {
  id          Int      @id @default(autoincrement())
  userId      String
  guildId     String
  moderatorId String
  reason      String
  createdAt   DateTime @default(now())

  target    GuildMember @relation("KickTarget",    fields: [userId, guildId],      references: [userId, guildId], onDelete: Restrict)
  moderator GuildMember @relation("KickModerator", fields: [moderatorId, guildId], references: [userId, guildId], onDelete: Restrict)

  @@index([userId, guildId])
}

model WarnLog {
  id          Int      @id @default(autoincrement())
  userId      String
  guildId     String
  moderatorId String
  reason      String
  createdAt   DateTime @default(now())

  target    GuildMember @relation("WarnTarget",    fields: [userId, guildId],      references: [userId, guildId], onDelete: Restrict)
  moderator GuildMember @relation("WarnModerator", fields: [moderatorId, guildId], references: [userId, guildId], onDelete: Restrict)

  @@index([userId, guildId])
}

model GuildRankConfig {
  guildId   String
  rankLevel Int
  name      String

  @@id([guildId, rankLevel])
}

model GuildFlairPool {
  guildId String
  emoji   String
  label   String?

  @@id([guildId, emoji])
}

model GuildSetting {
  guildId    String  @id
  banGifMode Boolean @default(true)
}

model BanLog {
  id          Int      @id @default(autoincrement())
  userId      String
  guildId     String
  moderatorId String
  reason      String
  createdAt   DateTime @default(now())

  target    GuildMember @relation("BanTarget",    fields: [userId, guildId],      references: [userId, guildId], onDelete: Restrict)
  moderator GuildMember @relation("BanModerator", fields: [moderatorId, guildId], references: [userId, guildId], onDelete: Restrict)

  @@index([userId, guildId])
}

model ClanMember {
  playerTag  String    @id
  playerName String?
  clanTag    String?
  userId     String?   // Discord userId — null if not linked
  guildId    String?   // Discord guildId — null if not linked
  linkedAt   DateTime?
  leftAt     DateTime? // set when player leaves clan; null = currently active
  updatedAt  DateTime  @updatedAt

  donationSnapshots DonationSeasonSnapshot[]
  discordMember     GuildMember? @relation(fields: [userId, guildId], references: [userId, guildId])

  @@index([userId])
  @@index([clanTag])
  @@index([leftAt])
}

model DonationSeasonSnapshot {
  playerTag              String
  seasonKey              String
  baselineAchievement    Int
  currentSeasonDonations Int      @default(0)
  finalDonations         Int?
  createdAt              DateTime @default(now())

  member ClanMember @relation(fields: [playerTag], references: [playerTag], onDelete: Cascade)

  @@id([playerTag, seasonKey])
  @@index([seasonKey])
  @@index([playerTag])
}
